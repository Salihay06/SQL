CREATE TABLE MOVIES(
title VARCHAR(100),
year INT,
lenght INT,
genre VARCHAR(10),
studioName VARCHAR(30),
producerCNo INT,
PRIMARY KEY(title,year)
FOREIGN KEY(producerCNo) REFERENCES MOVIEEXEC(certNo)
);
CREATE TABLE MOVIESTAR(
name VARCHAR(50),
address VARCHAR(100),
gender CHAR,
birthdate DATE,
PRIMARY KEY(name)
);
CREATE TABLE STARSIN(
movieTitle VARCHAR(100),
movieYear DATE,
starName VARCHAR(50),
PRIMARY KEY(movieTitle,movieYear,starName)
FOREIGN KEY(movieTitle) REFERENCES MOVIES(title)
FOREIGN KEY(starName) REFERENCES MOVIESTAR(name)
);
CREATE TABLE MOVIEEXEC(
name VARCHAR(50),
address VARCHAR(100),
certNo INT,
netWorth DATE,
PRIMARY KEY(certNo)
);
CREATE TABLE STUDIO(
name VARCHAR(50),
address VARCHAR(100),
presCNo INT,
PRIMARY KEY(name)
FOREIGN KEY(presCNo) REFERENCES MOVIEEXEC(certNo)
);
