LEFT JOIN orders o ON u.id= o.user_id;
-------------------------------------------------------------
                   right JOIN
kesişim ve ssğ kümeyi getirir ssğ taraftaki tablonu tğm degerlerini getiri

SELECT * FROM users u
RIGHT JOIN orders o ON u.id= o.user_id;
