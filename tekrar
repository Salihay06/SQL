                      FULL OUTER JOIN 
2 dairenin tamamı
SELECT * FROM users u
RIGHT JOIN orders o ON u.id= o.user_id;
-----------------------------------------------------------
LEFT ANTI-JOIN (Sadece Sola Ait Olanlar)

SELECT * FROM users u
LEFT JOIN orders o ON u.id = o.user_id
WHERE o.user_id IS NULL; 
----------------------------------------------------------
CROSS JOIN (Kartezyen Çarpım / Tüm Kombinasyonlar)
SELECT * FROM users u
CROSS JOIN orders o;
